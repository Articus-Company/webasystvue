{
    "name": "webasystvue",
    "type": "module",
    "version": "0.7.0",
    "scripts": {
        "build": "npm run type-check && vite build",
        "build-only": "vite build",
        "watch": "vite build --watch",
        "type-check": "vue-tsc -p tsconfig.build.json --noEmit",
        "pub:release": "pnpm publish --no-git-checks --access public"
    },
    "sideEffects": false,
    "exports": {
        ".": {
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Articus-Company/webasystvue.git"
    },
    "keywords": [
        "ui",
        "vue",
        "components",
        "webasyst"
    ],
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "src",
        "dist",
        "!src/**/*.story.vue",
        "!src/**/*.test.*",
        "!src/**/_*.vue",
        "!src/**/__snapshots__",
        "!src/**/stories",
        "!src/**/story"
    ],
    "peerDependencies": {
        "vue": "^3.5.33"
    },
    "dependencies": {
        "@vueuse/core": "^14.3.0",
        "class-variance-authority": "^0.7.1",
        "reka-ui": "^2.9.6"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/node": "^24.10.9",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/tsconfig": "^0.9.1",
        "@microsoft/api-extractor": "^7.58.7",
        "clsx": "^2.1.1",
        "jiti": "^2.6.1",
        "tsx": "^4.21.0",
        "vite": "^8.0.10",
        "vite-plugin-dts": "^5.0.0",
        "vue-tsc": "^3.2.7"
    }
}
