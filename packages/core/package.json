{
    "name": "webasystvue",
    "version": "0.8.0",
    "keywords": [
        "ui",
        "vue",
        "components",
        "webasyst"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Articus-Company/webasystvue.git"
    },
    "license": "MIT",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "src",
        "dist",
        "!src/**/*.story.vue",
        "!src/**/*.test.*",
        "!src/**/_*.vue",
        "!src/**/__snapshots__",
        "!src/**/stories",
        "!src/**/story"
    ],
    "scripts": {
        "build": "pnpm type-check && pnpm build-only",
        "build-only": "tsdown",
        "pub:release": "pnpm publish --no-git-checks --access public",
        "type-check": "vue-tsc -p tsconfig.build.json --noEmit",
        "watch": "tsdown --watch"
    },
    "dependencies": {
        "@vueuse/core": "^14.3.0",
        "class-variance-authority": "^0.7.1",
        "reka-ui": "^2.9.6"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.7",
        "@tsconfig/node24": "^24.0.4",
        "@types/node": "^24.10.9",
        "@vue/tsconfig": "^0.9.1",
        "clsx": "^2.1.1",
        "jiti": "^2.6.1",
        "tsdown": "^0.21.10",
        "tsx": "^4.21.0",
        "unplugin-vue": "^7.2.0",
        "vue-tsc": "^3.2.8"
    },
    "peerDependencies": {
        "vue": "^3.5.33"
    }
}
