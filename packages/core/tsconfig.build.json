{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "compilerOptions": {
        "incremental": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "declaration": true,
        "declarationMap": true,
        "paths": {
            "@/*": ["./src/*"],
            "@lib/*": ["./lib/*"]
        },
        "skipLibCheck": true
    },
    "vueCompilerOptions": {},
    "include": ["env.d.ts", "src/**/*", "src/**/*.ts", "src/**/*.vue", "lib/**/*.ts"]
}
